# Telegram
TELEGRAM_BOT_TOKEN=

# MongoDB (optional)
MONGODB_URI=

# RapidAPI TikTok downloader
RAPIDAPI_KEY=
RAPIDAPI_HOST=

# Optional: base URL for your RapidAPI TikTok endpoint.
# If left as the placeholder (example.p.rapidapi.com), downloading is disabled and the bot will tell you to configure it.
RAPIDAPI_TIKTOK_ENDPOINT_BASE=https://example.p.rapidapi.com

# Optional controls
COOLDOWN_SECONDS=10
HTTP_TIMEOUT_MS=30000

# Optional: downloader resilience
TIKTOK_MAX_RETRIES=2
TIKTOK_RETRY_BASE_MS=800
TIKTOK_RETRY_MAX_MS=8000
TIKTOK_COOLDOWN_MS=60000

# Optional: downloader RPS limits
TIKTOK_GLOBAL_RPS=5
TIKTOK_USER_RPS=1
